# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Security
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
MASTER_API_KEY=kyc_master_changeme
API_KEY_PREFIX=kyc_live_

# Storage
STORAGE_PATH=./storage

# Database
DB_PATH=./kyc.db

# Sessions
SESSION_TTL_HOURS=24
SESSION_TOKEN_TTL_HOURS=2

# Processing
JOB_POLL_INTERVAL_MS=500
JOB_MAX_CONCURRENCY=4

# Face matching threshold (0.0 - 1.0, lower = stricter)
FACE_MATCH_THRESHOLD=0.5

# Risk scoring thresholds
RISK_APPROVE_THRESHOLD=0.80
RISK_MANUAL_THRESHOLD=0.55

# Address doc max age in days
ADDRESS_DOC_MAX_AGE_DAYS=90

# CORS origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
